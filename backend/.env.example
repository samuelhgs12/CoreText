# Chave de API do Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key_here

# Modelo usado para geração dos resumos (opcional, valor padrão abaixo)
GEMINI_MODEL=gemini-2.5-flash

# Segredo usado para assinar os tokens de autenticação do backend
AUTH_SECRET_KEY=change-this-in-production

# Tempo de vida do token de acesso, em minutos
AUTH_TOKEN_TTL_MINUTES=10080
