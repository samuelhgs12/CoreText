# ============================================================================
# GEMINI API Configuration
# ============================================================================
# Chave de API do Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key_here

# Modelo usado para geração dos resumos (opcional, valor padrão abaixo)
GEMINI_MODEL=gemini-2.5-flash


# ============================================================================
# Authentication Configuration
# ============================================================================
# Segredo usado para assinar os tokens de autenticação do backend
AUTH_SECRET_KEY=change-this-in-production

# Tempo de vida do token de acesso, em minutos
AUTH_TOKEN_TTL_MINUTES=10080


# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
# Usuário do PostgreSQL
POSTGRES_USER=coretext

# Senha do PostgreSQL (ALTERAR EM PRODUÇÃO)
POSTGRES_PASSWORD=dev_password

# Nome do banco de dados
POSTGRES_DB=coretext

# URL de conexão com o banco de dados
# Format: postgresql://user:password@host:port/database
# Para Docker Compose Dev: postgresql://coretext:dev_password@database:5432/coretext
# Para Docker Compose Prod: postgresql://coretext:password_prod@database:5432/coretext
DATABASE_URL=postgresql://coretext:dev_password@localhost:5432/coretext


# ============================================================================
# Application Configuration
# ============================================================================
# Nível de logging (debug, info, warning, error, critical)
LOG_LEVEL=info

# Modo debug (True para desenvolvimento, False para produção)
DEBUG=False

# Porta da aplicação (usado em desenvolvimento)
API_PORT=8000
